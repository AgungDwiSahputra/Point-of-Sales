---
import '../styles/global.css';
import PosApp from '../islands/PosApp';

// BASE_URL kadang berakhiran "/" kadang tidak, tergantung konfigurasi - normalisasi dulu
// supaya tidak salah gabung (mis. "/Point-of-Salesfavicon.svg" tanpa slash pemisah).
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="id">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href={`${base}/icons/icon-192.png`} />
		<link rel="icon" href={`${base}/favicon.ico`} />
		<link rel="manifest" href={`${base}/manifest.webmanifest`} />
		<link rel="apple-touch-icon" href={`${base}/icons/icon-192.png`} />
		<meta name="theme-color" content="#1874dd" />
		<meta name="viewport" content="width=device-width, viewport-fit=cover" />
		<meta name="generator" content={Astro.generator} />
		<title>Sahma.id — POS System</title>
	</head>
	<body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
		<PosApp client:only="preact" />
		<script>
			import '../pwa';
		</script>
	</body>
</html>

