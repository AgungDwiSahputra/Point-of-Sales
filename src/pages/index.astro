---
import '../styles/global.css';
import PosApp from '../islands/PosApp';

// BASE_URL kadang berakhiran "/" kadang tidak, tergantung konfigurasi - normalisasi dulu
// supaya tidak salah gabung (mis. "/Point-of-Salesfavicon.svg" tanpa slash pemisah).
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="id">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<link rel="icon" href={`${base}/favicon.ico`} />
		<link rel="manifest" href={`${base}/manifest.webmanifest`} />
		<link rel="apple-touch-icon" href={`${base}/icons/icon-192.png`} />
		<meta name="theme-color" content="#2563eb" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>POS</title>
	</head>
	<body class="min-h-screen bg-gray-50 text-gray-900">
		<div class="mx-auto max-w-4xl p-4">
			<PosApp client:only="preact" />
		</div>
		<script>
			import '../pwa';
		</script>
	</body>
</html>

